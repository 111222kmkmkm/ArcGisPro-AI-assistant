<UserControl x:Class="ArcGISProAddin.WorkflowDockPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ArcGISProAddin"
             MinWidth="280">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    <local:BoolToExpandIconConverter x:Key="BoolToExpandIcon"/>
    <local:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVis"/>

    <Style x:Key="StepCard" TargetType="Border">
      <Setter Property="Background" Value="#2D2D30"/>
      <Setter Property="BorderBrush" Value="#3F3F46"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Margin" Value="4,2"/>
    </Style>
  </UserControl.Resources>

  <Grid Background="#1E1E1E">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#252526" Padding="10,8">
      <StackPanel>
        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[wf.title]}" FontSize="14" FontWeight="Bold" Foreground="#CCCCCC"/>
        <TextBlock Text="{Binding WorkflowTitle}"
                   FontSize="12"
                   Foreground="#9CDCFE"
                   Margin="0,2,0,0"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Background="#2D2D30"
            Padding="8,6"
            Visibility="{Binding HasWorkflow, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Button Command="{Binding RunAllCommand}"
                Content="Run All"
                Background="#0E639C"
                Foreground="White"
                BorderBrush="#0E639C"
                Padding="12,5"
                Margin="4,0"
                Cursor="Hand"/>
        <Button Command="{Binding StepByStepCommand}"
                Content="Step Run"
                Background="#3C3C3C"
                Foreground="#CCCCCC"
                BorderBrush="#555555"
                Padding="12,5"
                Margin="4,0"
                Cursor="Hand"/>
        <Button Command="{Binding ClearCommand}"
                Content="Clear"
                Background="Transparent"
                Foreground="#888888"
                BorderBrush="Transparent"
                Padding="8,5"
                Margin="4,0"
                ToolTip="Clear workflow"
                Cursor="Hand"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="4">
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="#888888"
                   FontSize="12"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="16,40"
                   Visibility="{Binding HasWorkflow, Converter={StaticResource InverseBoolToVis}}"/>

        <ItemsControl ItemsSource="{Binding Steps}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Style="{StaticResource StepCard}">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>

                  <Grid Grid.Row="0" Margin="8,8,8,6">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="28"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{Binding StatusColor}"
                            CornerRadius="12"
                            Width="22"
                            Height="22"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding StepId}"
                                 Foreground="White"
                                 FontSize="10"
                                 FontWeight="Bold"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 Foreground="#E8E8E8"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Tool}"
                                 FontSize="10"
                                 Foreground="#666666"
                                 FontFamily="Consolas"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Command="{Binding EditParamsCommand}"
                            Content="Edit"
                            Background="Transparent"
                            Foreground="#888888"
                            BorderBrush="Transparent"
                            Padding="4,2"
                            ToolTip="Edit parameters"
                            FontSize="11"
                            Cursor="Hand"/>

                    <Button Grid.Column="3"
                            Command="{Binding ToggleExpandCommand}"
                            Content="{Binding IsExpanded, Converter={StaticResource BoolToExpandIcon}}"
                            Background="Transparent"
                            Foreground="#666666"
                            BorderBrush="Transparent"
                            Padding="4,2"
                            FontSize="10"
                            Cursor="Hand"/>
                  </Grid>

                  <Border Grid.Row="1"
                          Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                          Background="#1A1A1A"
                          Margin="4,0,4,6"
                          CornerRadius="3"
                          Padding="8">
                    <StackPanel>
                      <TextBlock Text="{Binding Description}"
                                 FontSize="11"
                                 Foreground="#AAAAAA"
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,6"/>
                      <TextBox Text="{Binding ParamsJson, Mode=OneWay}"
                               FontFamily="Consolas"
                               FontSize="10"
                               Foreground="#9CDCFE"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               IsReadOnly="True"
                               TextWrapping="Wrap"
                               MaxHeight="200"
                               VerticalScrollBarVisibility="Auto"/>
                      <TextBlock Text="{Binding ErrorMessage}"
                                 Foreground="#F14C4C"
                                 FontSize="11"
                                 TextWrapping="Wrap"
                                 Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVis}}"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="3"
            Background="#007ACC"
            Padding="8,4"
            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="Running..." Foreground="White" FontSize="12"/>
        <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11" Margin="8,0,0,0"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
