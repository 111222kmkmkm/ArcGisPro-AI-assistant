<UserControl x:Class="ArcGISProAddin.AIChatDockPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ArcGISProAddin"
             MinWidth="300">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style x:Key="BubbleRow" TargetType="Grid">
      <Setter Property="Margin" Value="8,4"/>
    </Style>
  </UserControl.Resources>

  <Grid Background="#1E1E1E">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#252526" Padding="10,8">
      <StackPanel>
        <Grid>
          <StackPanel>
            <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.title]}" FontSize="13" FontWeight="Bold" Foreground="#CCCCCC"/>
            <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.subtitle]}" FontSize="10" Foreground="#888888"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button Command="{Binding ConnectFolderCommand}"
                    Content="📁 连接文件夹"
                    FontSize="11"
                    Background="Transparent"
                    Foreground="#BBBBBB"
                    BorderBrush="Transparent"
                    Padding="6,2"
                    Margin="0,0,4,0"
                    ToolTip="选择文件夹，AI可读取其中的文件"
                    Cursor="Hand"/>
            <Button Command="{Binding OpenSettingsCommand}"
                    Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.title]}"
                    FontSize="11"
                    Background="Transparent"
                    Foreground="#BBBBBB"
                    BorderBrush="Transparent"
                    Padding="6,2"
                    ToolTip="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.settingsTip]}"
                    Cursor="Hand"/>
          </StackPanel>
        </Grid>
        <TextBlock Text="{Binding ConnectedFolderDisplay}"
                   FontSize="10" Foreground="#6A9955"
                   Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1"
                  x:Name="MessagesScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <ItemsControl ItemsSource="{Binding Messages}" x:Name="MessagesList">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Style="{StaticResource BubbleRow}">
              <Border HorizontalAlignment="{Binding Alignment}"
                      Background="{Binding BubbleBackground}"
                      CornerRadius="12"
                      Padding="12,8"
                      MaxWidth="300">
                <StackPanel>
                  <TextBlock Text="{Binding Content}"
                             Foreground="{Binding TextColor}"
                             FontSize="12"
                             TextWrapping="Wrap"
                             LineHeight="18"/>
                  <TextBlock Text="{Binding TimestampText}"
                             Foreground="#666666"
                             FontSize="9"
                             HorizontalAlignment="Right"
                             Margin="0,4,0,0"/>
                </StackPanel>
              </Border>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="#007ACC"
            Padding="8,3"
            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal">
        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.thinking]}" Foreground="White" FontSize="11"/>
        <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="11" Margin="8,0,0,0"/>
      </StackPanel>
    </Border>

    <Border Grid.Row="3" Background="#252526" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox Grid.Column="0"
                 x:Name="InputTextBox"
                 Text="{Binding InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Background="#2D2D30"
                 Foreground="#E8E8E8"
                 BorderBrush="#555555"
                 BorderThickness="1"
                 Padding="8,6"
                 FontSize="12"
                 AcceptsReturn="False"
                 TextWrapping="Wrap"
                 MaxHeight="100"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Center"
                 CaretBrush="White"
                 KeyDown="OnInputKeyDown">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="CaretBrush" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <Button Grid.Column="1"
                Command="{Binding SendCommand}"
                Content="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.send]}"
                FontSize="12"
                FontWeight="Bold"
                Background="#0E639C"
                Foreground="White"
                BorderBrush="Transparent"
                Width="56"
                Height="38"
                Margin="6,0,0,0"
                ToolTip="{Binding Source={x:Static local:Loc.Instance}, Path=[chat.sendTip]}"
                Cursor="Hand">
          <Button.Style>
            <Style TargetType="Button">
              <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Background" Value="#2D2D30"/>
                  <Setter Property="Foreground" Value="#444444"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </Button.Style>
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>
