<Window x:Class="ArcGISProAddin.AISettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ArcGISProAddin"
        Title="{Binding Source={x:Static local:Loc.Instance}, Path=[set.title]}"
        Height="440"
        Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize">

  <Window.Resources>
    <Style TargetType="Label">
      <Setter Property="Foreground" Value="#CCCCCC"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="0,0,0,2"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#2D2D30"/>
      <Setter Property="Foreground" Value="#9CDCFE"/>
      <Setter Property="BorderBrush" Value="#555555"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#2D2D30"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
      <Setter Property="BorderBrush" Value="#555555"/>
      <Setter Property="Padding" Value="6,4"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="14,6"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- 0 API Key label -->
      <RowDefinition Height="Auto"/>  <!-- 1 API Key box -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- 3 Base URL label -->
      <RowDefinition Height="Auto"/>  <!-- 4 Base URL box -->
      <RowDefinition Height="Auto"/>  <!-- 5 Base URL hint -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- 7 Model label -->
      <RowDefinition Height="Auto"/>  <!-- 8 Model row -->
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>  <!-- 10 Language label -->
      <RowDefinition Height="Auto"/>  <!-- 11 Language combo -->
      <RowDefinition Height="*"/>     <!-- 12 status spacer -->
      <RowDefinition Height="Auto"/>  <!-- 13 status text -->
      <RowDefinition Height="Auto"/>  <!-- 14 buttons -->
    </Grid.RowDefinitions>

    <Label Grid.Row="0" FontWeight="SemiBold"
           Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.apiKey]}"/>
    <PasswordBox Grid.Row="1"
                 x:Name="ApiKeyBox"
                 Background="#2D2D30" Foreground="#9CDCFE"
                 BorderBrush="#555555" Padding="6,4"
                 FontFamily="Consolas" FontSize="12"/>

    <Label Grid.Row="3"
           Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.baseUrl]}"/>
    <TextBox Grid.Row="4" x:Name="BaseUrlBox"/>
    <TextBlock Grid.Row="5" Margin="0,3,0,0" FontSize="10" Foreground="#777"
               Text="{Binding Source={x:Static local:Loc.Instance}, Path=[set.baseUrlHint]}"/>

    <Label Grid.Row="7"
           Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.model]}"/>
    <Grid Grid.Row="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <ComboBox Grid.Column="0" x:Name="ModelCombo" IsEditable="True"/>
      <Button Grid.Column="1" x:Name="FetchBtn" Click="OnFetchModels"
              Margin="8,0,0,0"
              Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"
              Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.fetchModels]}"/>
    </Grid>

    <Label Grid.Row="10"
           Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.language]}"/>
    <ComboBox Grid.Row="11" x:Name="LanguageCombo"
              SelectionChanged="OnLanguageChanged">
      <ComboBoxItem Content="中文" Tag="zh"/>
      <ComboBoxItem Content="English" Tag="en"/>
    </ComboBox>

    <TextBlock Grid.Row="13"
               x:Name="StatusText"
               Foreground="#888888" FontSize="11"
               TextWrapping="Wrap"
               Margin="0,0,0,8"/>

    <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Click="OnCancel"
              Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"
              Margin="0,0,8,0"
              Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.cancel]}"/>
      <Button Click="OnTest"
              Background="#3C3C3C" Foreground="#CCCCCC" BorderBrush="#555555"
              Margin="0,0,8,0"
              Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.test]}"/>
      <Button Click="OnSave"
              Background="#0E639C" Foreground="White" BorderBrush="Transparent"
              Content="{Binding Source={x:Static local:Loc.Instance}, Path=[set.save]}"/>
    </StackPanel>
  </Grid>
</Window>
